# Copy this file to .env and fill in your values

# Your Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Path to the OAuth2 credentials JSON downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json

# Where the OAuth token is cached after first login (auto-created)
GMAIL_TOKEN_PATH=token.pickle

# Output Excel file path
EXCEL_PATH=job_applications.xlsx

# How often (in minutes) to re-scan emails when running in loop mode
SCAN_INTERVAL_MINUTES=60
